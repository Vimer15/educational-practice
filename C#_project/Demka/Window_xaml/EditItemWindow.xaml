<Window x:Class="Demka.window_xaml.EditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" Height="650" Width="500"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   x:Name="TitleText"
                   Text="Редактирование товара" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10"/>

        <!-- Артикул -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Артикул:" VerticalAlignment="Center" Margin="10"/>
        <TextBox x:Name="ArticuleTB" Grid.Row="1" Grid.Column="1" Height="30" Margin="10" 
                 IsReadOnly="False" Background="White" ToolTip="Максимум 6 символов"/>

        <!-- Описание -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:" VerticalAlignment="Center" Margin="10"/>
        <TextBox x:Name="DescriptionTB" Grid.Row="2" Grid.Column="1" Height="60" Margin="10" 
                 TextWrapping="Wrap" ToolTip="Максимум 500 символов"/>

        <!-- Единица измерения -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Единица измерения:" VerticalAlignment="Center" Margin="10"/>
        <TextBox x:Name="MeasurementTB" Grid.Row="3" Grid.Column="1" Height="30" Margin="10" 
                 ToolTip="Максимум 20 символов"/>

        <!-- Цена -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Цена:" VerticalAlignment="Center" Margin="10"/>
        <TextBox x:Name="PriceTB" Grid.Row="4" Grid.Column="1" Height="30" Margin="10"/>

        <!-- Скидка -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Скидка (%):" VerticalAlignment="Center" Margin="10"/>
        <TextBox x:Name="DiscountTB" Grid.Row="5" Grid.Column="1" Height="30" Margin="10"/>

        <!-- Поставщик -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Поставщик:" VerticalAlignment="Center" Margin="10"/>
        <ComboBox x:Name="SupplierCB" Grid.Row="6" Grid.Column="1" Height="30" Margin="10" 
                  DisplayMemberPath="NameSupplier" SelectedValuePath="IdSupplier"/>

        <!-- Производитель -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Производитель:" VerticalAlignment="Center" Margin="10"/>
        <ComboBox x:Name="ManufactureCB" Grid.Row="7" Grid.Column="1" Height="30" Margin="10" 
                  DisplayMemberPath="NameManufacture" SelectedValuePath="IdManufacture"/>

        <!-- Категория -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Категория:" VerticalAlignment="Center" Margin="10"/>
        <ComboBox x:Name="CategoryCB" Grid.Row="8" Grid.Column="1" Height="30" Margin="10" 
                  DisplayMemberPath="NameItemCategory" SelectedValuePath="IdItemCategory"/>

        <!-- Количество на складе -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Количество на складе:" VerticalAlignment="Center" Margin="10"/>
        <TextBox x:Name="CountTB" Grid.Row="9" Grid.Column="1" Height="30" Margin="10"/>

        <!-- Фото -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Фото:" VerticalAlignment="Center" Margin="10"/>
        <Grid Grid.Row="10" Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image x:Name="PreviewImage" Grid.Row="0" Width="100" Height="100" Margin="0 0 0 5" 
                   Stretch="Uniform"/>
            <Button x:Name="SelectPhotoBtn" Grid.Row="1" Content="Выбрать фото" Height="30" 
                    Click="SelectPhotoBtn_Click"/>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="100" Height="35" Margin="5" 
                    Background="#FF4CAF50" Foreground="White" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="35" Margin="5" 
                    Background="#FFF44336" Foreground="White" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>