<Window x:Class="Demka.window_xaml.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demka.window_xaml"
        mc:Ignorable="d"
        Title="Добавление/Редактирование заказа" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Код заказа -->
        <TextBlock Grid.Row="0" Text="Код заказа:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" Name="CodeTextBox" Margin="0,0,0,10" Padding="5"/>

        <!-- Статус заказа -->
        <TextBlock Grid.Row="2" Text="Статус заказа:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="3" Name="StatusComboBox" Margin="0,0,0,10" Padding="5">
            <ComboBoxItem Content="Новый" Tag="New" IsSelected="True"/>
            <ComboBoxItem Name="StatusEnd" Content="Завершен" Tag="Completed"/>
        </ComboBox>

        <!-- Адрес пункта выдачи -->
        <TextBlock Grid.Row="4" Text="Адрес пункта выдачи:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="5" Name="PickupPointComboBox" Margin="0,0,0,10" Padding="5"
                  DisplayMemberPath="FullAddress" SelectedValuePath="IdPickupPoint"/>

        <!-- Даты -->
        <Grid Grid.Row="6" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Дата заказа:" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker DisplayDateStart="12.03.2026" Name="OrderDatePicker" SelectedDateFormat="Short" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Дата доставки:" FontWeight="Bold" Margin="0,0,0,5"/>
                <DatePicker DisplayDateEnd="12.03.2027" Name="DeliveryDatePicker" SelectedDateFormat="Short" Padding="5"/>
            </StackPanel>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" 
                    Background="#00FA9A" Foreground="White" BorderThickness="0"
                    Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Background="Gray" Foreground="White" BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>