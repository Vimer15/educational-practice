<Window x:Class="Demka.window_xaml.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowState="Maximized"
        Title="Каталог товара" Height="450" Width="800">
    <Grid>
        <Grid Background="Chartreuse" Height="120" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Source="C:\Users\rusla\source\repos\Demka\Demka\images\Icon.ico" 
                   Grid.RowSpan="2" Width="70" Height="70" 
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20 0"/>

            <TextBlock Grid.Row="0" x:Name="UserNameTB" Grid.Column="1" 
                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="24"
                       Margin="20 0"/>
            <TextBlock x:Name="UserRoleTB" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="24"
                Margin="10,0,0,0" Width="444" Grid.Column="1"/>

            <Button Grid.Row="1" x:Name="AddItemWindow" Content="Добавить товар" FontSize="18" 
                    Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" 
                    HorizontalContentAlignment="Center" 
                    Background="#FF21A04E" BorderBrush="White" Margin="0,0,20,0" 
                    Padding="0 5" Width="180" Foreground="White" Click="AddItemWindow_Click"/>

            <Button Grid.Row="1" x:Name="Zakazi" Content="Заказы" FontSize="18" 
                    Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
                    HorizontalContentAlignment="Center" 
                    Background="#FF792D2D" BorderBrush="White" Margin="290,0,0,9" 
                    Padding="0 5" Width="90" Foreground="White" Click="Zakazi_Click"/>

            <Button Grid.Row="1" x:Name="ExitBtn" Content="Выйти из аккаунта" FontSize="18" 
                    Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" 
                    HorizontalContentAlignment="Center" Click="ExitBtn_Click" 
                    Background="#FFFF7272" BorderBrush="White" Margin="0,0,20,0" 
                    Padding="0 5" Width="180" Foreground="White"/>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" 
                       HorizontalAlignment="Center" Margin="10" VerticalAlignment="Center">

                <!-- Поиск -->
                <TextBox x:Name="SearchTB" Width="200" Height="30" 
                        Margin="5" Padding="5" 
                        TextChanged="SearchTB_TextChanged"
                        ToolTip="Введите текст для поиска"/>

                <!-- Фильтр по поставщику -->
                <ComboBox x:Name="SupplierFilterCB" Width="150" Height="30" 
                         Margin="5" 
                         SelectionChanged="Filter_Changed"
                         ToolTip="Фильтр по поставщику">
                    <ComboBoxItem Content="Все поставщики" IsSelected="True"/>
                </ComboBox>

                <!-- Сортировка -->
                <ComboBox x:Name="SortCB" Width="150" Height="30" 
                         Margin="5" 
                         SelectionChanged="Sort_Changed"
                         ToolTip="Сортировка">
                    <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                    <ComboBoxItem Content="По цене (возрастание)"/>
                    <ComboBoxItem Content="По цене (убывание)"/>
                    <ComboBoxItem Content="По количеству (возрастание)"/>
                    <ComboBoxItem Content="По количеству (убывание)"/>
                </ComboBox>

            </StackPanel>
        </Grid>

        <!-- Счетчик результатов -->
        <TextBlock x:Name="ResultCountTB" 
                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Margin="10" FontSize="14" Foreground="Gray"
                  Panel.ZIndex="1"/>

        <ListBox x:Name="ItemsLB" Margin="0 150 0 0" 
                HorizontalContentAlignment="Stretch"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                MouseDoubleClick="ItemsLB_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2" Margin="5">
                        <!-- Контекстное меню для администратора (убраны имена) -->
                        <Border.ContextMenu>
                            <ContextMenu Opened="ContextMenu_Opened">
                                <MenuItem Header="Редактировать" Click="EditMenuItem_Click"/>
                                <MenuItem Header="Удалить" Click="DeleteMenuItem_Click"/>
                            </ContextMenu>
                        </Border.ContextMenu>

                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border BorderBrush="Black" BorderThickness="2" Grid.Column="0" Margin="5">
                                <Image Source="{Binding Photo}" Width="200" Height="200" 
                                      Stretch="Uniform"/>
                            </Border>

                            <Border BorderBrush="Black" BorderThickness="2" Grid.Column="1" Margin="5">
                                <Grid Margin="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding CategoryName}" Grid.Row="0" 
                                              FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Text="{Binding Description}" Grid.Row="1" FontSize="18"
                                              TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Manufacture}" Grid.Row="2" FontSize="18"/>
                                    <TextBlock Text="{Binding Supplier}" Grid.Row="3" FontSize="18"/>

                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        <TextBlock Text="Цена:" FontSize="18" Margin="0 0 4 0"/>
                                        <TextBlock Text="{Binding PriceItem}" Grid.Row="4" FontSize="18" 
                                                  Margin="0 0 4 0" Foreground="{Binding PriceColor}" 
                                                  TextDecorations="{Binding PriceStyle}"/>
                                        <TextBlock Text="{Binding Price}" Grid.Row="4" FontSize="18"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Measurement}" Grid.Row="5" FontSize="18"/>
                                    <TextBlock Text="{Binding CountInStorage}" 
                                              Background="{Binding CountInStorageStyle}" 
                                              Grid.Row="6" FontSize="18"/>
                                </Grid>
                            </Border>

                            <Border BorderBrush="Black" BorderThickness="2" Grid.Column="2" Margin="5">
                                <TextBlock Text="{Binding Discount}" Margin="5" FontSize="18"
                                          TextAlignment="Center" VerticalAlignment="Center" 
                                          Background="{Binding DiscountColor}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>