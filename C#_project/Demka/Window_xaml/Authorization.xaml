<Window x:Class="Demka.window_xaml.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demka.window_xaml"
        WindowState="Maximized"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Авторизация" FontSize="24" HorizontalAlignment="Center" Margin="0 0 0 20"></TextBlock>
            <TextBlock Text="Введите логин:" FontSize="18"></TextBlock>
            <TextBox x:Name="LoginTB" MaxLength="100" Width="250" Margin="0 10 0 10" FontSize="18" BorderBrush="MediumSpringGreen"></TextBox>
            <TextBlock Text="Введите пароль:" FontSize="18"></TextBlock>
            <TextBox x:Name="PasswordTB" MaxLength="45" Width="250" Margin="0 10 0 10" FontSize="18" BorderBrush="MediumSpringGreen"></TextBox>
            <Button x:Name="LoginBtn" Content="Войти" FontSize="18" Padding="0 5" Margin="0 0 0 10" Background="Chartreuse" BorderBrush="MediumSpringGreen" Click="LoginBtn_Click"></Button>
            <Button x:Name="LoginAsGuestBtn" Content="Войти как гость" FontSize="18" Padding="0 5" Background="Chartreuse" BorderBrush="#FF307FCF" Click="LoginAsGuestBtn_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
