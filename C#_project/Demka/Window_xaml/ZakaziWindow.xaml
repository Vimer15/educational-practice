<Window x:Class="Demka.window_xaml.ZakaziWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demka.window_xaml"
        mc:Ignorable="d"
        Title="Страница заказов" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Grid.ColumnSpan="4"  Background="#FF7FFF00"/>
        <TextBlock Name="RoleUserTBL" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
        <TextBlock Name="FIOUserTBL" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" TextWrapping="Wrap"/>
        <Button Name="ReturnBTN" Content="Назад" FontSize="18" Background="#FFFFEA85" Grid.Column="3" Height="50" Width="100" BorderBrush="Black" Click="ReturnBTN_Click"/>

        <!-- Панель управления заказами -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
            <Button Name="addOrderBTN" Content="Добавить заказ" 
                    Width="150" Height="35" Margin="5" 
                    Background="#00FA9A" Foreground="White" BorderThickness="0"
                    Click="addOrderBTN_Click"
                    Visibility="Collapsed"/>

            <Button Name="EditOrderBTN" Content="Редактировать" 
                    Width="150" Height="35" Margin="5" 
                    Background="#FFA500" Foreground="White" BorderThickness="0"
                    Click="EditOrderBTN_Click"
                    Visibility="Collapsed"/>

            <Button Name="DeleteOrderBTN" Content="Удалить заказ" 
                    Width="150" Height="35" Margin="5" 
                    Background="#FF4444" Foreground="White" BorderThickness="0"
                    Click="DeleteOrderBTN_Click"
                    Visibility="Collapsed"/>
        </StackPanel>

        <!-- Список заказов -->
        <ScrollViewer Grid.Row="2" Grid.ColumnSpan="4">
            <StackPanel>
                <ListView Name="OrderBoxLV" HorizontalContentAlignment="Stretch" 
                          SelectionMode="Single"
                          MouseDoubleClick="OrderBoxLV_MouseDoubleClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5" Margin="5" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Левая часть - фото товара -->
                                    <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Margin="5" Padding="5">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Image Source="{Binding OrderItems[0].Photo}" Width="80" Height="80" 
                                                   Stretch="UniformToFill" Margin="0,0,0,5">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="../Images/picture.png"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OrderItems[0].Photo}" Value="{x:Null}">
                                                                <Setter Property="Source" Value="../Images/picture.png"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="Фото товара" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Центральная часть - основная информация -->
                                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Margin="5" Padding="5">
                                        <StackPanel>
                                            <TextBlock FontSize="16" FontWeight="Bold" Text="Заказ №" Foreground="#00FA9A"/>
                                            <TextBlock FontSize="16" Text="{Binding Id}" Margin="0,0,0,5"/>

                                            <TextBlock FontSize="14" FontWeight="Bold" Text="Статус:"/>
                                            <TextBlock FontSize="14" Text="{Binding Status}" Margin="0,0,0,5">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="Black"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RawStatus}" Value="Completed">
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RawStatus}" Value="New">
                                                                <Setter Property="Foreground" Value="Orange"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock FontSize="14" FontWeight="Bold" Text="Адрес:"/>
                                            <TextBlock FontSize="14" Text="{Binding FullAddress}" 
                                                       TextWrapping="Wrap" Margin="0,0,0,5"/>

                                            <TextBlock FontSize="14" FontWeight="Bold" Text="Дата заказа:"/>
                                            <TextBlock FontSize="14" Text="{Binding DateOrderingString}"/>

                                            <TextBlock FontSize="12" Text="{Binding OrderItems.Count, StringFormat='Товаров в заказе: {0} шт.'}" 
                                                       Foreground="Gray" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Правая часть - дата доставки -->
                                    <Border Grid.Column="2" BorderBrush="Black" BorderThickness="2" Margin="5" Padding="5">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontSize="14" FontWeight="Bold" Text="Дата доставки:" 
                                                       TextWrapping="Wrap" TextAlignment="Center"/>
                                            <TextBlock FontSize="16" Text="{Binding DateDeliveryString}" 
                                                       FontWeight="Bold" Foreground="#00FA9A" 
                                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>